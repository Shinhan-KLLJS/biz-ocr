# Ncloud CLOVA OCR 호출 정보입니다. 사업자등록증은 Document OCR 전용 URL을 권장합니다.
NCLOUD_OCR_BIZ_LICENSE_API_URL=https://YOUR_INVOKE_URL.apigw.ntruss.com/custom/v1/YOUR_DOMAIN_ID/YOUR_DEPLOY_ID/document/biz-license
NCLOUD_OCR_API_URL=https://YOUR_INVOKE_URL.apigw.ntruss.com/custom/v1/YOUR_DOMAIN_ID/YOUR_DEPLOY_ID/general
NCLOUD_OCR_SECRET_KEY=YOUR_SECRET_KEY

NCLOUD_BIZ_OCR_API_URL=https://YOUR_INVOKE_URL.apigw.ntruss.com/custom/v1/YOUR_DOMAIN_ID/YOUR_DEPLOY_ID/document/biz-license
NCLOUD_BIZ_OCR_SECRET_KEY=YOUR_SECRET_KEY

# OCR 입력으로 허용할 S3 버킷입니다. 운영 환경에서는 반드시 설정합니다.
# 비워두면 호출자가 지정한 어떤 버킷이든 읽습니다.
OCR_INPUT_BUCKET=

# OCR 기본 옵션입니다. 요청 event의 lang, timeout, templateIds가 있으면 요청 값이 우선합니다.
NCLOUD_OCR_LANG=ko
NCLOUD_OCR_VERSION=V2
NCLOUD_OCR_TIMEOUT=60
NCLOUD_OCR_TEMPLATE_IDS=
NCLOUD_OCR_MAX_FILE_BYTES=52428800

# 사업자등록증 진위 확인(data.go.kr)은 이 Lambda가 아니라 서버가 수행합니다.
# 검증 규칙은 docs/server-verification-spec.md를 참고하세요.
